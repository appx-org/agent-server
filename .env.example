# required
PROJECT_DIR=/abs/path/to/your/app

# optional (with defaults)
# AGENT_SERVER_MODE=single
# SESSIONS_DIR=$PROJECT_DIR/data/sessions
# AGENTS_FILE=.pi/AGENTS.md
# AGENT_SERVER_HOST=127.0.0.1
# AGENT_SERVER_PORT=4001

# optional — pi auth
# ANTHROPIC_API_KEY=

# optional — bearer auth on /v1/*. Leave unset for loopback-only single-user dev.
# AGENT_SERVER_TOKEN=
