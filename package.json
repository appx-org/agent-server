{
  "name": "@appx/agent-server",
  "private": true,
  "version": "0.1.0",
  "description": "Pi-SDK-based agent orchestration server for standalone and project-scoped sessions.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "bin": {
    "agent-server": "dist/server.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch --env-file-if-exists=.env src/server.ts",
    "start": "node --env-file-if-exists=.env dist/server.js",
    "openapi": "tsx --env-file-if-exists=.env src/openapi.ts",
    "test": "tsx --test test/*.test.ts"
  },
  "dependencies": {
    "@earendil-works/pi-coding-agent": "0.75.4",
    "@hono/node-server": "^1.13.7",
    "@hono/swagger-ui": "^0.5.1",
    "@hono/zod-openapi": "^0.19.2",
    "hono": "^4.6.14",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
